# malwar configuration
# Copy this file to .env and fill in values

# Anthropic API key for LLM semantic analysis (Layer 3)
MALWAR_ANTHROPIC_API_KEY=

# API authentication keys (comma-separated)
MALWAR_API_KEYS=

# Database path (default: malwar.db in current directory)
MALWAR_DB_PATH=malwar.db

# API server settings
MALWAR_API_HOST=127.0.0.1
MALWAR_API_PORT=8000

# LLM settings (Anthropic). Use a current model ID — older snapshots retire and
# then 404, which silently disables the LLM analysis layer.
MALWAR_LLM_MODEL=claude-sonnet-5
MALWAR_LLM_SKIP_BELOW_RISK=15

# URL crawler settings
MALWAR_CRAWLER_MAX_URLS=10
MALWAR_CRAWLER_TIMEOUT=5.0

# Logging
MALWAR_LOG_LEVEL=INFO
MALWAR_LOG_FORMAT=json

# X / Twitter publishing for `malwar crawl monitor --publish` (OAuth 1.0a).
# Leave empty to disable posting. Keep these secret — never commit real values.
MALWAR_X_API_KEY=
MALWAR_X_API_SECRET=
MALWAR_X_ACCESS_TOKEN=
MALWAR_X_ACCESS_TOKEN_SECRET=
